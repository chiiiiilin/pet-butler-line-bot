# Copy this file to .ship.env and fill in real values.
# .ship.env is gitignored.

# EC2 elastic IP (or DNS)
EC2_HOST=YOUR_ELASTIC_IP_HERE

# SSH login user (ubuntu / ec2-user)
EC2_USER=ubuntu

# Absolute path to your .pem key on this Mac
SSH_KEY=$HOME/path/to/your-key.pem

# Remote directory on EC2 to drop image tar & compose file
REMOTE_DIR=/home/ubuntu/pet-butler

# Optional: image tag (default: latest)
# TAG=latest
